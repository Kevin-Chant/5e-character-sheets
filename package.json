{
  "name": "5e-character-sheets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "vite",
    "server": "node server/server.js",
    "build": "pnpm generate-schema && pnpm type-check && vite build",
    "preview": "vite preview",
    "screenshot": "node scripts/screenshot.mjs",
    "generate-schema": "typescript-json-schema src/lib/types.ts Character --required > src/schema.json && prettier --write src/schema.json --log-level silent",
    "schema:check": "pnpm generate-schema && git diff --exit-code -- src/schema.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0 --cache || eslint . --fix --max-warnings 0 --cache",
    "lint:ci": "eslint . --max-warnings 0",
    "pretty": "prettier --write \"**/*.{json,css,md,js,jsx,ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ci": "pnpm schema:check && pnpm lint:ci && pnpm type-check && pnpm test",
    "prepare": "husky || true"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "autobahn-browser": "^22.11.1",
    "classnames": "^2.5.1",
    "lodash": "^4.17.21",
    "nightlife-rabbit": "github:christian-raedel/nightlife-rabbit",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "react-router-dom": "^6.30.0",
    "react-switch": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/gapi": "^0.0.47",
    "@types/gapi.client.drive": "^3.0.15",
    "@types/google.accounts": "^0.0.14",
    "@types/google.picker": "^0.0.52",
    "@types/lodash": "^4.17.14",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.19.0",
    "typescript-json-schema": "^0.65.1",
    "vite": "^6.0.7",
    "vitest": "^3.2.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
