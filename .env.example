# Copy this file to `.env.local` and adjust for your deployment.
# All VITE_* values are read at build time and SHIPPED TO THE BROWSER — they are
# not secrets. They exist so self-hosters can point at their own Google Cloud
# app and live-edit server instead of the project defaults.

# Google OAuth client ID and API key (Drive appdata scope).
# Create your own at https://console.cloud.google.com/ for a self-hosted deploy.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Default live-editing sidecar server the app connects to. Users can also
# override this per-device in the in-app settings page.
VITE_LIVE_EDIT_HOST=http://localhost:9000

# Port the live-edit sidecar server (`pnpm server`) listens on. Defaults to 9000.
PORT=9000
